//Use fastfetch -h <module>-format to see available format options for each module.
{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "general": {
        "detectVersion": true
    },
    "modules": [
        "title",
        "break",
        {
            "type": "os",
            "key": "󰣇 OS",
            "keyColor": "blue"
        },
        {
            "type": "host",
            "key": "󰌢 Host",
            "keyColor": "cyan"
        },
        {
            "type": "kernel",
            "key": "󰒋 Kernel",
            "keyColor": "green"
        },
        {
            "type": "uptime",
            "key": "󰔚 Uptime",
            "keyColor": "yellow"
        },
        {
            "type": "packages",
            "key": "󰏗 Packages",
            "keyColor": "magenta"
        },
        {
            "type": "shell",
            "key": "󰆍 Shell",
            "keyColor": "blue"
        },
        {
            "type": "display",
            "key": "󰍹 Display ({name})",
            "keyColor": "cyan"
        },
        {
            "type": "de",
            "key": "󰧨 DE",
            "keyColor": "magenta"
        },
        {
            "type": "wm",
            "key": "󱂬 WM",
            "keyColor": "magenta"
        },
        {
            "type": "wmtheme",
            "key": "󰉼 WM Theme",
            "keyColor": "magenta"
        },
        {
            "type": "theme",
            "key": "󰉼 Theme",
            "keyColor": "magenta"
        },
        {
            "type": "icons",
            "key": "󰀻 Icons",
            "keyColor": "magenta"
        },
        {
            "type": "font",
            "key": "󰛖 Font",
            "keyColor": "yellow"
        },
        {
            "type": "cursor",
            "key": "󰇀 Cursor",
            "keyColor": "yellow"
        },
        {
            "type": "terminal",
            "key": " Terminal",
            "keyColor": "green"
        },
        {
            "type": "terminalfont",
            "key": "󰛖 Terminal Font",
            "keyColor": "yellow"
        },
        {
            "type": "cpu",
            "key": "󰻠 CPU",
            "keyColor": "red"
        },
        {
            "type": "gpu",
            "key": "󰢮 GPU {index}",
            "keyColor": "red"
        },
        {
            "type": "memory",
            "key": "󰍛 Memory",
            "keyColor": "green"
        },
        {
            "type": "swap",
            "key": "󰓡 Swap",
            "keyColor": "green"
        },
        {
            "type": "disk",
            "key": "󰋊 Disk ({mountpoint})",
            "keyColor": "cyan"
        },
        {
            "type": "localip",
            "key": "󰩟 Local IP ({ifname})",
            "keyColor": "blue"
        },
        {
            "type": "battery",
            "key": "󰁹 Battery ({name})",
            "keyColor": "yellow"
        },
        {
            "type": "poweradapter",
            "key": "󰚥 Adapter",
            "keyColor": "yellow"
        },
        {
            "type": "locale",
            "key": "󰗊 Locale",
            "keyColor": "white"
        },
        "break",
        {
            "type": "colors"
        }
    ],
    "logo": {
        "type": "auto",
        "source": "~/.config/fastfetch/logo.jpeg",
        "width": 40
    }
}
